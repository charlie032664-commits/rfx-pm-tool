# RFX PM Tool — local LLM config (TEMPLATE)
#
# Copy this file to .env and fill in values locally:
#     copy .env.example .env        (Windows)
#     cp   .env.example .env        (macOS/Linux)
#
# .env is gitignored — never commit real secrets or internal URLs.
# OS environment variables (setx / launcher) always take precedence over .env.
# Restart Streamlit after editing .env so the new values are picked up.

# ── Internal / self-hosted OpenAI-compatible provider ───────────────────────
LLM_PROVIDER=internal
INTERNAL_LLM_BASE_URL=
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=

# ── OpenAI provider (uncomment this block and comment the internal one above) ─
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# ── Optional ────────────────────────────────────────────────────────────────
# LLM_TIMEOUT_SECONDS=120
